# codex-wrapper environment configuration
# Copy to .env and fill in real values. Never commit .env.
#
# ── Environment ─────────────────────────────────────────────────────────────
WRAPPER_ENV=dev                          # dev | staging | prod

# ── Database ─────────────────────────────────────────────────────────────────
# asyncpg URL used by the gateway/worker at runtime.
# Alembic env.py strips +asyncpg for sync migrations.
DATABASE_URL=postgresql+asyncpg://codex:codex@localhost:5432/codex_wrapper

# Main request pool — sized for 100 RPS × 50ms p99 with headroom.
# 1 uvicorn worker per replica × 30 max conns = 30/replica.
# With N replicas: ensure Postgres max_connections > N×33 + ~12 headroom.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=2.0                      # seconds; fast 503 instead of 30s hang

# Background writes pool — fire-and-forget audit/last_used_at updates.
# Times out and DROPS writes on contention — must not block request path.
BG_DB_POOL_SIZE=3
BG_DB_POOL_TIMEOUT=0.5

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Codex CLI ────────────────────────────────────────────────────────────────
CODEX_BIN=codex                          # Full path if not on PATH
CODEX_AUTH_DIR=/codex-auth               # Container path of ~/.codex RO bind-mount

# Host path to ~/.codex — compose mounts this into gateway + worker containers.
# Default: ${HOME}/.codex (set explicitly if your home dir is non-standard)
# NOTE: Use ${HOME}, not ~ — Compose does not expand tilde.
#       Compose creates a literal '~' directory at the project root if you use ~.
CODEX_AUTH_HOST_DIR=${HOME}/.codex

# Set to true after 'make verify-codex' confirms --ephemeral exists in the
# pinned codex version. Default false = fail-safe (no --ephemeral flag).
CODEX_HAS_EPHEMERAL=false

# Interval between background Codex auth-session health probes (seconds).
CODEX_SESSION_POLL_INTERVAL_SECONDS=300

# Timeout for 'codex auth status' subprocess probe (seconds).
CODEX_AUTH_PROBE_TIMEOUT_SECONDS=3

# ── Workspaces ───────────────────────────────────────────────────────────────
WORKSPACE_ROOT=/workspaces               # Parent directory for ephemeral job dirs

# ── Job lifecycle ────────────────────────────────────────────────────────────
JOB_TIMEOUT_SECONDS=900                  # 15 min; phase-05 enforces this via arq
JOB_CANCEL_GRACE_SECONDS=5              # SIGTERM window before SIGKILL

# ── Responses API (/v1/responses) ────────────────────────────────────────────
RESPONSES_TIMEOUT_SECONDS=120            # Per-request timeout (sync or stream)
RESPONSES_CHUNK_CHARS=50                 # Text-delta chunk window in chars (streaming simulation)
RESPONSES_MAX_INPUT_CHARS=200000         # Max assembled input length in characters

# ── Auth ─────────────────────────────────────────────────────────────────────
# Admin token for /admin/* endpoints. Rotate periodically.
# In prod: must be a strong random secret (min 32 chars). Never log or commit.
# The gateway raises ValidationError at startup if this is the placeholder in prod.
ADMIN_TOKEN=replace-me-in-prod

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR

# ── OpenTelemetry ────────────────────────────────────────────────────────────
# Leave unset for no-op tracer (default for local dev).
# Set to your collector endpoint to enable tracing.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=codex-wrapper-gateway
# Fraction of requests to sample for traces (0.0–1.0). Default 10%.
# Error spans always sampled. Set to 1.0 for debug; 0.01 for very high traffic.
OTEL_SAMPLER_RATIO=0.1

# ── Metrics ───────────────────────────────────────────────────────────────────
# Enable Prometheus metrics endpoint (true/false).
METRICS_ENABLED=true
# Internal path for Prometheus scrape — Caddy MUST NOT proxy this path.
# Only the Prometheus container should reach this over the internal Docker network.
INTERNAL_METRICS_PATH=/_internal/metrics
# Prometheus base URL the admin dashboard queries for KPIs and sparklines.
# In docker-compose: http://prometheus:9090. Leave unset to fall back to local
# /_internal/metrics text-format parsing (no historical sparklines).
PROMETHEUS_URL=http://prometheus:9090

# ── Production deploy (phase 10) ─────────────────────────────────────────────
# GitHub Container Registry org/user for image pulls in docker-compose.production.yml.
# GHCR_ORG=your-org

# Image tag to deploy (set by GH Actions or manually for rollback).
# IMAGE_TAG=v0.1.0

# ── Backup (phase 10) ─────────────────────────────────────────────────────────
# age public key for backup encryption. Generate: age-keygen -o key.txt; public key in stdout.
# Keep the private key offline (ops lead only). Never commit it.
# BACKUP_AGE_RECIPIENT=age1ql3z7hjy54pw3hyww5ayyfg7zqgvc7w3j2elw8zmrj2kg5sfn9aqmcac8p

# S3 / Cloudflare R2 / Backblaze B2 bucket for encrypted backups.
# BACKUP_S3_BUCKET=codex-wrapper-backups

# Optional: override S3 endpoint for R2/B2/MinIO.
# BACKUP_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# AWS credentials for backup upload (or use instance IAM profile).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── Alerting (phase 10) ───────────────────────────────────────────────────────
# Slack incoming webhook URL for alert notifications.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# PagerDuty routing key. Leave unset to disable PD (alerts go to Slack only).
# PAGERDUTY_KEY=

# ── Access gate (phase 10) ────────────────────────────────────────────────────
# Informational: documents which access gate is in use.
# Values: caddy-ip | tailscale | cloudflare
# ACCESS_GATE_KIND=caddy-ip

# ── Grafana (phase 10) ────────────────────────────────────────────────────────
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=replace-me-in-prod
